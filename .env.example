# OpenAI API Keys
OPENROUTER_API_KEY=sk-or-v1-

# Для локальных моделей (Ollama/vLLM) ключ не нужен, но переменная должна быть, 
# чтобы код не упал с ошибкой "API key not found". Можно оставить EMPTY.
LOCAL_API_KEY=EMPTY 

# Optional: separate key for embeddings (if not set, uses OPENAI_API_KEY)
# OPENAI_EMBEDDING_API_KEY=sk-proj-...your-embedding-key...

# For CI/CD environments, set these as secrets:
# - OPENAI_API_KEY
# - OPENAI_EMBEDDING_API_KEY (optional)
